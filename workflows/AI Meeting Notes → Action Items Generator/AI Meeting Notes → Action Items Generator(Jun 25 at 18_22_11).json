    {
      "parameters": {
        "jsCode": "const items = $json.data;\n\nconst summary = items[0][\"Meeting Summary\"];\nconst decision = items[0][\"Decision\"].join(\"\\n• \");\n\nlet emailBody = `📋 Meeting Summary\n\n${summary}\n\n----------------------------------------\n\n📌 Key Decision(s)\n\n• ${decision}\n\n----------------------------------------\n\n✅ Action Items\n\n`;\n\nitems.forEach((item, index) => {\n  emailBody += `${index + 1}. ${item.Owner}\n\nTask: ${item.Task}\nDeadline: ${item.Deadline ?? item.Dealine}\nPriority: ${item.Priority}\n\n`;\n});\n\nreturn [\n  {\n    json: {\n      subject: \"Meeting Summary & Action Items\",\n      emailBody\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1520,
        32
      ],
      "id": "7ef57952-8a16-4bec-b4b5-154e58cef266",
      "name": "Generate Email Summary"
