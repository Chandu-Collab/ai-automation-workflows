    {
      "parameters": {
        "jsCode": "// Get all input rows\nconst rows = $input.all().map(item => item.json);\n\n// Sort by date (old → new)\nrows.sort((a, b) => {\n  const d1 = new Date(a.Date.split(\"/\").reverse().join(\"-\"));\n  const d2 = new Date(b.Date.split(\"/\").reverse().join(\"-\"));\n  return d1 - d2;\n});\n\n// Create formatted string for AI\nlet formatted = \"\";\n\nrows.forEach(r => {\n  formatted += `Date: ${r.Date} | Sales: ${r.Sales} | Leads: ${r.Leads} | Revenue: ${r.Revenue}\\n`;\n});\n\n// Return SINGLE item (very important)\nreturn [\n  {\n    json: {\n      formatted_data: formatted,\n      raw: rows\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        64,
        16
      ],
      "id": "3fdad262-ccba-4ab5-a8ea-d026b059a44f",
      "name": "Format & Prepare Data"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Generate a concise daily business report based on the data below.\n\nFocus on:\n- What changed\n- Why it changed\n- What actions should be taken\n\nData:\n{{ $json.formatted_data }}",
        "options": {
          "systemMessage": "You are an expert business analyst and growth advisor.\n\nGenerate a concise daily business report for decision-makers.\n\nStructure:\n\n1. Key Insights (2–3 bullets)\n2. What Changed (based only on data)\n3. Growth Actions (clear, practical steps)\n4. Risk Alerts (only if critical)\n\nRules:\n- Keep it short and email-friendly\n- Do NOT use tables\n- Do NOT speculate beyond data\n- Ensure all numerical comparisons are accurate\n- Do not make incorrect percentage calculations\n- Only include insights supported by the data\n- Use bullet points for clarity\n- Always use ₹ for currency and no other symbols\n\nTone:\n- Direct\n- Clear\n- Action-oriented"
        }
      },
