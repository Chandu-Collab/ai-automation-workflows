        "jsonBody": "={\n  \"model\": \"meta/llama-3.1-70b-instruct\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a strict JSON generator. Always return valid JSON only.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Analyze the following YouTube transcript and return ONLY JSON.\\n\\nTitle: {{$json.title}}\\n\\nTranscript:\\n{{$json.cleanTranscript}}\\n\\nReturn format:\\n{\\n  \\\"topic\\\": \\\"\\\",\\n  \\\"summary\\\": \\\"\\\",\\n  \\\"key_points\\\": [],\\n  \\\"hooks\\\": []\\n}\"\n    }\n  ],\n  \"temperature\": 0.2,\n  \"top_p\": 0.7,\n  \"max_tokens\": 1024,\n  \"stream\": false\n}",
