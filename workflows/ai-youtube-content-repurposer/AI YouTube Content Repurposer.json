        "parameters": {
          "jsCode": "const url = $json.body.youtube_url;\n\nif (!url) {\n  throw new Error(\"youtube_url not found\");\n}\n\n// handle multiple formats\nlet videoId = null;\n\n// standard format\nlet match = url.match(/v=([^&]+)/);\nif (match) {\n  videoId = match[1];\n}\n\n// short format (youtu.be)\nif (!videoId) {\n  match = url.match(/youtu\\.be\\/([^?]+)/);\n  if (match) videoId = match[1];\n}\n\nreturn [{\n  videoId,\n  originalUrl: url\n}];"
        },
