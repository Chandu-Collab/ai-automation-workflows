    {
      "parameters": {
        "jsCode": "const raw = $json.choices[0].message.content.trim();\n\n// extract JSON safely\nconst jsonStart = raw.indexOf(\"{\");\nconst jsonString = raw.slice(jsonStart);\n\nconst data = JSON.parse(jsonString);\n\nreturn [{\n  topic: data.topic,\n  summary: data.summary,\n  key_points: data.key_points,\n  hooks: data.hooks\n}];"
