        "jsCode": "let text = $json.text;\n\n// basic cleanup\ntext = text.replace(/\\s+/g, ' ').trim();\n\n// optional: limit size (VERY IMPORTANT for AI)\ntext = text.slice(0, 8000);\n\nreturn [{\n  cleanTranscript: text,\n  title: $json.videoTitle\n}];"
